generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  role                Role                 @default(USER)
  // Account lockout fields
  loginAttempts       Int                  @default(0)
  lockedUntil         DateTime?
  accounts            Account[]
  sessions            Session[]
  bids                Bid[]
  passwordResetTokens PasswordResetToken[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  token   String   @unique
  expires DateTime
  userId  String
  used    Boolean  @default(false)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Auction {
  id            String    @id @default(cuid())
  title         String
  description   String
  imageUrl      String?
  startingPrice Float
  currentPrice  Float
  endTime       DateTime
  status        String    @default("ACTIVE") // ACTIVE, CLOSED, DELETED
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bids          Bid[]

  @@index([status])
  @@index([endTime])
}

model Bid {
  id        String   @id @default(cuid())
  amount    Float
  createdAt DateTime @default(now())
  userId    String
  auctionId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
  @@index([userId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model InventoryItem {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  category    String
  condition   String
  imageUrl    String?
  ownerName   String
  ownerEmail  String
  status      String   @default("PENDING") // PENDING, STORED, RETURNED
  createdAt   DateTime @default(now())

  @@index([status])
}

model RestorationRequest {
  id          String   @id @default(cuid())
  itemName    String
  description String   @db.Text
  damage      String   @db.Text
  ownerName   String
  ownerEmail  String
  ownerPhone  String
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  createdAt   DateTime @default(now())

  @@index([status])
}

model AdvisoryRequest {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  itemType      String
  message       String   @db.Text
  preferredDate String?
  status        String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED
  createdAt     DateTime @default(now())

  @@index([status])
}

model TradeOffer {
  id              String   @id @default(cuid())
  offererName     String
  offererEmail    String
  offeredItem     String
  offeredDesc     String   @db.Text
  offeredImageUrl String?
  wantedItem      String
  wantedDesc      String   @db.Text
  status          String   @default("OPEN") // OPEN, CLOSED
  createdAt       DateTime @default(now())

  @@index([status])
}
