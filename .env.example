# ============================================================
# VAULT — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ============================================================

# --- Database ---
# Local PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/vault_auction?schema=public"

# --- NextAuth ---
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"
# Set to your production URL when deploying
NEXTAUTH_URL="http://localhost:3000"

# --- Email (Nodemailer) ---
# For local dev/college use, leave these empty.
# Ethereal test accounts will be auto-created and email links logged to console.
# For real sending, use Gmail App Password or any SMTP provider.
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="\"VAULT Auctions\" <noreply@vault.local>"

# Admin email to receive contact form notifications
ADMIN_EMAIL="admin@vault.local"
